# ─── OBRIGATÓRIO ──────────────────────────────────────────────────────────────

# Token do bot (obtenha no @BotFather no Telegram)
TELEGRAM_TOKEN=seu_token_aqui

# Username do canal (com @) ou ID numérico do canal
# Exemplo: @meucanaldeofertas   ou   -1001234567890
TELEGRAM_CHANNEL=@seu_canal_aqui

# ─── RECOMENDADO (gratuito) ───────────────────────────────────────────────────

# API Key do Google Gemini para gerar headlines de vendas automáticas
# Obtenha gratuitamente em: https://aistudio.google.com/app/apikey
# Se deixar em branco, o bot funciona normalmente sem headlines de IA
GEMINI_API_KEY=sua_api_key_aqui

# ─── OPCIONAL ─────────────────────────────────────────────────────────────────

# Intervalo entre verificações de promoções (em minutos). Padrão: 15
CHECK_INTERVAL_MINUTES=15

# Máximo de deals postados por rodada (evita flood). Padrão: 5
MAX_DEALS_PER_RUN=5

# Porta do dashboard web. Railway define isso automaticamente via $PORT.
# Só altere se estiver rodando localmente e a porta 5000 estiver ocupada.
PORT=5000

# Caminho do arquivo SQLite (padrão: deals.db na raiz do projeto)
DB_PATH=deals.db
